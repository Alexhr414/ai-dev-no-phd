{
  "_comment": "Add this to ~/Library/Application Support/Claude/claude_desktop_config.json (Mac)",
  "mcpServers": {
    "hello-mcp": {
      "command": "python",
      "args": ["/absolute/path/to/examples/part6-mcp-server/01_hello_mcp.py"]
    },
    "database-mcp": {
      "command": "python",
      "args": ["/absolute/path/to/examples/part6-mcp-server/02_database_server.py"],
      "env": {
        "DATABASE_PATH": "/path/to/your/database.db"
      }
    }
  }
}
